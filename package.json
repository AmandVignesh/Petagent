{
  "name": "loli-windows",
  "version": "1.0.0",
  "description": "LOLI Focus Companion - Offline Windows App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.14",
    "@tensorflow-models/face-detection": "^1.0.2",
    "@tensorflow/tfjs-backend-wasm": "^4.20.0",
    "@tensorflow/tfjs-backend-webgl": "^4.20.0",
    "@tensorflow/tfjs-core": "^4.20.0",
    "dotenv": "^17.3.1",
    "face-api.js": "^0.22.2"
  },
  "build": {
    "appId": "com.loli.windows",
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "LOLI.exe"
    },
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}